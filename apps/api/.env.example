NODE_ENV=development
PORT=4000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fom_platform_api?schema=public"

JWT_ACCESS_SECRET="dev_access_secret_change_me_facebook_order_manager"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me_facebook_order_manager"

REDIS_URL="redis://localhost:6379/0"
WEB_APP_BASE_URL="http://localhost:3000"

# Public marketing & legal URLs (optional)
LEGAL_CONSENT_VERSION="2026-04-16"
PUBLIC_TERMS_URL=""
PUBLIC_PRIVACY_URL=""
PUBLIC_ACCOUNT_DELETION_URL=""

# Support links (optional)
PLATFORM_SUPPORT_LABEL="Contact support"
PLATFORM_SUPPORT_URL="http://localhost:3000/contact"

# Public contact form inbox (optional)
PUBLIC_CONTACT_INBOX_EMAIL=""
PUBLIC_CONTACT_IP_SALT=""
PUBLIC_CONTACT_RL_IP_LIMIT=5
PUBLIC_CONTACT_RL_IP_WINDOW_MS=3600000
PUBLIC_CONTACT_RL_EMAIL_LIMIT=3
PUBLIC_CONTACT_RL_EMAIL_WINDOW_MS=86400000

# Platform notice (optional)
PLATFORM_NOTICE_ENABLED=false
PLATFORM_NOTICE_SEVERITY=info
PLATFORM_NOTICE_AUDIENCE=all
PLATFORM_NOTICE_TITLE=""
PLATFORM_NOTICE_BODY=""
PLATFORM_NOTICE_CTA_LABEL=""
PLATFORM_NOTICE_CTA_URL=""

# Billing / payment instructions surfaced to tenants (optional)
PLATFORM_PAYMENT_CHANNELS=""
PLATFORM_PAYMENT_INSTRUCTIONS_TITLE="How to pay and activate your shop"
PLATFORM_PAYMENT_INSTRUCTIONS_BODY="After your trial, contact the platform team to receive your invoice and payment instructions. Access is activated once payment is confirmed."

DEFAULT_TRIAL_DAYS=7
REALTIME_JWT_SECRET=""
REALTIME_TICKET_TTL_SECONDS=120
PUSH_PROVIDER="disabled"

PLATFORM_OWNER_EMAIL=owner@fom-platform.local
PLATFORM_OWNER_PASSWORD=Password123!
PLATFORM_OWNER_NAME=Platform Admin

# Email
EMAIL_PROVIDER="log"
EMAIL_FROM_EMAIL="no-reply@fom-platform.local"
EMAIL_FROM_NAME="FOM Order Manager"
EMAIL_SUPPORT_EMAIL="support@fom-platform.local"
EMAIL_PRODUCT_NAME="FOM Order Manager"

# SendGrid
SENDGRID_API_KEY=""
EMAIL_SENDGRID_FROM_EMAIL=""
EMAIL_SENDGRID_FROM_NAME=""

# SMTP
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASSWORD=""
EMAIL_SMTP_IGNORE_TLS=false
EMAIL_SMTP_REQUIRE_TLS=false
EMAIL_SMTP_FROM_EMAIL=""
EMAIL_SMTP_FROM_NAME=""
