NODE_ENV=production
PORT=4000
PUBLIC_API_BASE_URL="https://api.getfom.com"
WEB_APP_BASE_URL="https://getfom.com"
CORS_ALLOWED_ORIGINS="https://getfom.com,https://app.getfom.com"
API_DOCS_ENABLED=false

DATABASE_URL="postgresql://postgres:postgres@postgres:5432/fom_platform_api?schema=public"
# Max connections for the pg pool used by Prisma (default 10)
PG_POOL_MAX=10

JWT_ACCESS_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"

DEFAULT_TRIAL_DAYS=7
REALTIME_JWT_SECRET=""
REALTIME_TICKET_TTL_SECONDS=300
PUSH_PROVIDER="disabled"

PLATFORM_OWNER_EMAIL="owner@getfom.com"
PLATFORM_OWNER_PASSWORD="Password123!"
PLATFORM_OWNER_NAME="Platform Admin"

# Public legal and support metadata
LEGAL_CONSENT_VERSION="2026-04-16"
PUBLIC_TERMS_URL="https://getfom.com/terms"
PUBLIC_PRIVACY_URL="https://getfom.com/privacy"
PUBLIC_ACCOUNT_DELETION_URL="https://getfom.com/account-deletion"
PLATFORM_SUPPORT_LABEL="Contact support"
PLATFORM_SUPPORT_URL="https://getfom.com/contact"

# Tenant billing instructions
PLATFORM_PAYMENT_CHANNELS="myanmyanpay"
PLATFORM_PAYMENT_INSTRUCTIONS_TITLE="How to pay and activate your shop"
PLATFORM_PAYMENT_INSTRUCTIONS_BODY=""

# Public contact form
PUBLIC_CONTACT_INBOX_EMAIL="support@getfom.com"
PUBLIC_CONTACT_IP_SALT="change_me_public_contact_salt"
PUBLIC_CONTACT_RL_IP_LIMIT=5
PUBLIC_CONTACT_RL_IP_WINDOW_MS=3600000
PUBLIC_CONTACT_RL_EMAIL_LIMIT=3
PUBLIC_CONTACT_RL_EMAIL_WINDOW_MS=86400000

# Email delivery
EMAIL_PROVIDER="smtp"
EMAIL_FROM_EMAIL="no-reply@getfom.com"
EMAIL_FROM_NAME="FOM Order Manager"
EMAIL_SUPPORT_EMAIL="support@getfom.com"
EMAIL_PRODUCT_NAME="FOM Order Manager"

# SendGrid
SENDGRID_API_KEY=""
EMAIL_SENDGRID_FROM_EMAIL=""
EMAIL_SENDGRID_FROM_NAME=""

# SMTP
EMAIL_SMTP_HOST="smtp.example.com"
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER="smtp-user"
EMAIL_SMTP_PASSWORD="smtp-password"
EMAIL_SMTP_IGNORE_TLS=false
EMAIL_SMTP_REQUIRE_TLS=false
EMAIL_SMTP_FROM_EMAIL="no-reply@getfom.com"
EMAIL_SMTP_FROM_NAME="FOM Order Manager"

# MyanMyanPay
MYANMYANPAY_APP_ID=""
MYANMYANPAY_PUBLISHABLE_KEY=""
MYANMYANPAY_PUBLIC_KEY=""
MYANMYANPAY_SECRET_KEY=""
MYANMYANPAY_API_BASE_URL="https://ezapi.myanmyanpay.com"
MYANMYANPAY_CALLBACK_URL="https://api.getfom.com/api/v1/payments/webhooks/myanmyanpay"
MYANMYANPAY_USE_SANDBOX=false
MYANMYANPAY_QR_EXPIRY_SECONDS=900

# Meta Messenger
META_APP_ID=""
META_APP_SECRET=""
META_LOGIN_CONFIG_ID=""
META_WEBHOOK_VERIFY_TOKEN=""
META_GRAPH_API_BASE_URL="https://graph.facebook.com"
META_GRAPH_API_VERSION="v25.0"
MESSENGER_TOKEN_ENCRYPTION_SECRET="change_me_messenger_token_secret"
